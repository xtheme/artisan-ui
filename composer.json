{
    "name": "xtheme/artisan-ui",
    "version": "1.0.0",
    "description": "Run your artisan commands by pressing buttons.",
    "keywords": [
        "laravel",
        "artisan",
        "ui"
    ],
    "homepage": "https://github.com/xtheme/artisan-ui",
    "license": "MIT",
    "authors": [
        {
            "name": "Loris Leiva",
            "email": "loris.leiva@gmail.com",
            "homepage": "https://lorisleiva.com",
            "role": "Developer"
        },
        {
            "name": "RB",
            "email": "xtgeme@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "spatie/laravel-package-tools": "^1.9"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^3.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Lorisleiva\\ArtisanUI\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lorisleiva\\ArtisanUI\\Tests\\": "tests"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest --colors=always",
        "test-coverage": "vendor/bin/pest --coverage-html coverage"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Lorisleiva\\ArtisanUI\\ArtisanUIServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "funding": [
        {
            "type": "github",
            "url": "https://github.com/sponsors/lorisleiva"
        }
    ]
}
